function sortInv(inv){return inv.slice().sort(function(a,b){return b.invoiceNo>a.invoiceNo?1:-1;});}

function getNextInvoiceNo(){
  var inv=DB.get('invoices');
  if(!inv.length){
    var y=new Date().getFullYear().toString().slice(-2);
    return y+'26001';
  }
  var nums=inv.map(function(i){return parseInt(i.invoiceNo)||0;}).filter(Boolean);
  var max=Math.max.apply(null,nums);
  return String(max+1);
}

