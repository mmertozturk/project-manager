function saveInvoice(id){
  var client=(document.getElementById('f-client')||{}).value.trim();
  var amount=pa((document.getElementById('f-amount')||{}).value);
  if(!client)return;
  if(!amount&&!id)return;
  var inv=DB.get('invoices');
  var item={
    id:id||uid(),
    client:client,
    invoiceNo:(document.getElementById('f-no')||{}).value.trim(),
    date:(document.getElementById('f-date')||{}).value||today(),
    dueDate:(document.getElementById('f-due')||{}).value||addDays(today(),30),
    status:(document.getElementById('f-status')||{}).value||'Beklemende',
    amount:amount
  };
  if(id){inv=inv.map(function(i){return i.id===id?item:i;});}
  else{inv.push(item);}
  // Save to customers if new client
  var klanten=DB.get('customers');
  if(!klanten.some(function(c){return c.name===client;})){
    klanten.push({id:uid(),name:client});
    localStorage.setItem('zzpm_customers',JSON.stringify(klanten));
  }
  DB.set('invoices',inv);
  closeSheet();
  renderInvoices();
}

function editInvoice(id){
  var i=DB.get('invoices').filter(function(x){return x.id===id;})[0];
  if(i)openInvoiceForm(i);
}

function deleteInvoice(id){
  closeSheet();
  customConfirm('Factuur verwijderen?',function(){
    DB.set('invoices',DB.get('invoices').filter(function(i){return i.id!==id;}));
    renderInvoices();
  });
}

