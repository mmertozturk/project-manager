function renderSettings(){
  var klanten=DB.get('customers');
  var rows=klanten.length?klanten.map(function(c){
    return'<div class="row">'
      +'<div class="row-main"><div class="row-name">'+c.name+'</div></div>'
      +'<button onclick="deleteKlant(\''+c.id+'\')" style="background:rgba(239,68,68,.12);border:none;color:var(--danger);border-radius:7px;padding:5px 12px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer;">Verwijderen</button>'
      +'</div>';
  }).join(''):'<div style="text-align:center;padding:20px;color:var(--muted2);font-size:13px;">Geen klanten</div>';

  document.getElementById('content').innerHTML=
    '<div class="page">'
    +'<div class="page-title">Instellingen</div>'
    +'<div class="card">'
      +'<div class="card-title">Klanten ('+klanten.length+')</div>'
      +rows
    +'</div>'
    +'</div>';
}

function openKlantForm(){
  openSheet(
    '<div class="sheet-header"><div class="sheet-title">Klant toevoegen</div><button class="sheet-close" onclick="closeSheet()">Sluiten</button></div>'
    +'<label class="fl">Naam</label><input id="kl-naam" class="form-input" placeholder="Klantnaam..."/>'
    +'<button class="btn-primary" onclick="saveKlant()">Toevoegen</button>'
    +'<button class="btn-secondary" onclick="closeSheet()">Annuleren</button>'
  );
  setTimeout(function(){var e=document.getElementById('kl-naam');if(e)e.focus();},150);
}

function saveKlant(){
  var naam=(document.getElementById('kl-naam')||{}).value.trim();
  if(!naam)return;
  var klanten=DB.get('customers');
  if(klanten.some(function(c){return c.name===naam;})){closeSheet();return;}
  klanten.push({id:uid(),name:naam});
  DB.set('customers',klanten);
  closeSheet();
  renderSettings();
}

function deleteKlant(id){
  customConfirm('Klant verwijderen?',function(){
    DB.set('customers',DB.get('customers').filter(function(c){return c.id!==id;}));
    renderSettings();
  });
}

// --- INIT ---
setTimeout(function(){var e=document.getElementById('login-user');if(e)e.focus();},200);
</script>
</div></body>
</html>
