  var td=today(),first=new Date(y,m,1),dow=(first.getDay()+6)%7,dim=new Date(y,m+1,0).getDate();
  var h='<div class="page"><div class="page-title">Kalender</div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><button id="cal-prev" style="background:var(--navy2);border:none;color:var(--text);border-radius:8px;width:36px;height:36px;font-size:18px;cursor:pointer">‹</button><div style="font-size:16px;font-weight:800">'+MONTHS[m]+' '+y+'</div><button id="cal-next" style="background:var(--navy2);border:none;color:var(--text);border-radius:8px;width:36px;height:36px;font-size:18px;cursor:pointer">›</button></div><div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:4px">';
  DAYS.forEach(function(d){h+='<div style="text-align:center;font-size:10px;font-weight:700;color:var(--muted2);padding:4px 0">'+d+'</div>';});
  h+='</div><div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px">';
  for(var i=0;i<dow;i++)h+='<div></div>';
  for(var d2=1;d2<=dim;d2++){var ds=y+'-'+String(m+1).padStart(2,'0')+'-'+String(d2).padStart(2,'0');var ev=evts[ds]||[],isT=(ds===td);var dots='';if(ev.some(function(e){return e.type==='inv';}))dots+='<div style="width:5px;height:5px;border-radius:50%;background:var(--success);margin:0 1px"></div>';if(ev.some(function(e){return e.type==='exp';}))dots+='<div style="width:5px;height:5px;border-radius:50%;background:var(--danger);margin:0 1px"></div>';h+='<div class="cal-day" data-ds="'+ds+'" style="background:'+(isT?'var(--blue)':'var(--navy2)')+';border-radius:8px;padding:6px 2px;text-align:center;cursor:'+(ev.length?'pointer':'default')+'"><div style="font-size:13px;font-weight:'+(isT?800:600)+';color:'+(isT?'#fff':'var(--text)')+'">'+d2+'</div><div style="display:flex;justify-content:center;margin-top:2px;min-height:7px">'+dots+'</div></div>';}
  h+='</div><div style="display:flex;gap:12px;margin-top:12px;font-size:11px"><div style="display:flex;align-items:center;gap:4px"><div style="width:8px;height:8px;border-radius:50%;background:var(--success)"></div>Vervaldatum</div><div style="display:flex;align-items:center;gap:4px"><div style="width:8px;height:8px;border-radius:50%;background:var(--danger)"></div>Uitgave</div></div></div>';
  document.getElementById('content').innerHTML=h;
  document.getElementById('cal-prev').addEventListener('click',function(){window._cm--;if(window._cm<0){window._cm=11;window._cy--;}drawCal(window._cy,window._cm);});
  document.getElementById('cal-next').addEventListener('click',function(){window._cm++;if(window._cm>11){window._cm=0;window._cy++;}drawCal(window._cy,window._cm);});
  document.querySelectorAll('.cal-day').forEach(function(day){day.addEventListener('click',function(){calDay(this.dataset.ds);});});
}
function calDay(ds){
  var ev=(window._evts||{})[ds]||[];if(!ev.length)return;
  var p=ds.split('-');
  var ov=document.createElement('div');ov.className='sheet-overlay';
  var sh=document.createElement('div');sh.className='sheet';sh.addEventListener('click',function(e){e.stopPropagation();});ov.addEventListener('click',function(){ov.remove();});
  var rows=ev.map(function(e){return'<div class="row"><div class="row-main"><div class="row-name">'+e.label+'</div><div class="row-sub">'+(e.type==='inv'?'Factuur':'Uitgave')+(e.status?' · '+e.status:'')+'</div></div><div class="row-amount" style="color:'+(e.type==='inv'?'var(--success)':'var(--danger)')+'">'+fmtEUR(e.amt)+'</div></div>';}).join('');
  sh.innerHTML='<div class="sheet-handle"></div><div class="sheet-header"><div class="sheet-title">'+p[2]+'/'+p[1]+'/'+p[0]+'</div><button id="cd-close" class="sheet-close">Sluiten</button></div><div class="card">'+rows+'</div>';
  ov.appendChild(sh);document.body.appendChild(ov);document.getElementById('cd-close').addEventListener('click',function(){ov.remove();});
}

function renderSettings(){
  var klanten=DB.get('customers');
  var rows=klanten.length?klanten.map(function(c){return'<div class="row"><div class="row-main"><div class="row-name">'+c.name+'</div></div><button class="del-klant" data-id="'+c.id+'" style="background:rgba(239,68,68,.12);border:none;color:var(--danger);border-radius:7px;padding:5px 12px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer">Verwijderen</button></div>';}).join(''):'<div style="text-align:center;padding:20px;color:var(--muted2);font-size:13px;">Geen klanten</div>';
  document.getElementById('content').innerHTML='<div class="page"><div class="page-title">Instellingen</div><div class="card"><div class="card-title">Klanten ('+klanten.length+')</div>'+rows+'</div></div>';
  document.querySelectorAll('.del-klant').forEach(function(btn){btn.addEventListener('click',function(){deleteKlant(this.dataset.id);});});
}
function openKlantForm(){
  var ov=document.createElement('div');ov.className='sheet-overlay';var sh=document.createElement('div');sh.className='sheet';sh.addEventListener('click',function(e){e.stopPropagation();});ov.addEventListener('click',function(){ov.remove();});
  sh.innerHTML='<div class="sheet-handle"></div><div class="sheet-header"><div class="sheet-title">Klant toevoegen</div><button id="kl-close" class="sheet-close">Sluiten</button></div><label class="fl">Naam</label><input id="kl-naam" class="form-input" placeholder="Klantnaam..."/><button id="kl-save" class="btn-primary">Toevoegen</button><button id="kl-cancel" class="btn-secondary">Annuleren</button>';
  ov.appendChild(sh);document.body.appendChild(ov);
  document.getElementById('kl-close').addEventListener('click',function(){ov.remove();});document.getElementById('kl-cancel').addEventListener('click',function(){ov.remove();});
  document.getElementById('kl-save').addEventListener('click',function(){var naam=(document.getElementById('kl-naam')||{}).value.trim();if(!naam)return;var klanten=DB.get('customers');if(!klanten.some(function(c){return c.name===naam;})){klanten.push({id:uid(),name:naam});DB.set('customers',klanten);}ov.remove();renderSettings();});
  setTimeout(function(){var e=document.getElementById('kl-naam');if(e)e.focus();},150);
}
function deleteKlant(id){customConfirm('Klant verwijderen?',function(){DB.set('customers',DB.get('customers').filter(function(c){return c.id!==id;}));renderSettings();});}

setTimeout(function(){var e=document.getElementById('login-user');if(e)e.focus();},200);
</script>
</body>
</html>
