function renderDashboard(){
  var inv=DB.get('invoices');
  var expP=DB.get('exp_personal');
  var expB=DB.get('exp_business');
  var paid=inv.filter(function(i){return i.status==='Betaald';}).reduce(function(s,i){return s+pa(i.amount);},0);
  var pend=inv.filter(function(i){return i.status==='Beklemende';}).reduce(function(s,i){return s+pa(i.amount);},0);
  var late=inv.filter(function(i){return i.status==='Gecikmis';}).reduce(function(s,i){return s+pa(i.amount);},0);
  var totalExp=[].concat(expP,expB).reduce(function(s,e){return s+pa(e.amount);},0);
  var res=paid*0.30;
  var net=paid-totalExp-res;
  var nc=net>=0?'var(--success)':'var(--danger)';

  // Recent invoices
  var recent=inv.slice().sort(function(a,b){return b.date>a.date?1:-1;}).slice(0,5);
  var rRows=recent.length?recent.map(function(i){
    var sc='status-'+i.status.toLowerCase().replace('İ','i').replace('ı','i');
