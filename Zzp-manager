<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#0d1b2a"/>
<title>ZZP Manager</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#0d1b2a;--navy:#122035;--navy2:#1a2d45;--navy3:#223558;--blue:#1a6fbf;--accent:#4fc3f7;--success:#10b981;--warn:#f59e0b;--danger:#ef4444;--text:#e2eaf4;--muted:#7a9bbf;--muted2:#4a6a8a;--border:#1e3352;--border2:#2d4a6a;--safe-bottom:env(safe-area-inset-bottom,0px);}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:var(--bg);font-family:'Plus Jakarta Sans',sans-serif;color:var(--text);overflow:hidden;}
#app{display:flex;flex-direction:column;height:100%;}
.top-bar{background:linear-gradient(135deg,#0d1b2a,#122035);border-bottom:1px solid var(--border);padding:12px 16px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.logo-icon{width:32px;height:32px;background:var(--blue);border-radius:9px;display:flex;align-items:center;justify-content:center;}
.app-name{font-size:15px;font-weight:800;}
.sync-status{font-size:9px;color:var(--muted2);margin-top:1px;}
.fab-top{background:var(--blue);color:#fff;border:none;border-radius:9px;padding:8px 14px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;}
#content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:calc(70px + var(--safe-bottom));}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(--navy);border-top:1px solid var(--border);display:flex;padding-bottom:var(--safe-bottom);z-index:10;}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 2px 8px;border:none;background:none;color:var(--muted2);font-size:9px;font-family:inherit;font-weight:700;cursor:pointer;}
.nav-btn.active{color:var(--accent);}
.nav-btn svg{width:20px;height:20px;}
.page{padding:16px;}
.page-title{font-size:20px;font-weight:800;margin-bottom:16px;}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
.stat{background:var(--navy2);border:1px solid var(--border);border-radius:12px;padding:14px;}
.stat-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;}
.stat-val{font-size:20px;font-weight:800;font-family:'JetBrains Mono',monospace;}
.card{background:var(--navy2);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:12px;}
.card-title{font-size:13px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;}
.row{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--border);}
.row:last-child{border-bottom:none;}
.row-main{flex:1;min-width:0;}
.row-name{font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.row-sub{font-size:11px;color:var(--muted);margin-top:2px;}
.row-amount{font-size:14px;font-weight:800;font-family:'JetBrains Mono',monospace;text-align:right;flex-shrink:0;margin-left:8px;}
.row-status{font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;margin-left:6px;flex-shrink:0;}
.status-openstaand{background:rgba(245,158,11,.15);color:var(--warn);}
.status-betaald{background:rgba(16,185,129,.15);color:var(--success);}
.status-telaat{background:rgba(239,68,68,.15);color:var(--danger);}
.status-geannuleerd{background:rgba(100,116,139,.15);color:#64748b;}
.sheet-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:100;display:flex;align-items:flex-end;}
.sheet{background:var(--navy);border-radius:20px 20px 0 0;width:100%;max-height:88vh;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:20px 18px calc(20px + var(--safe-bottom));border-top:1px solid var(--border2);}
.sheet-handle{width:40px;height:4px;background:var(--border2);border-radius:99px;margin:0 auto 16px;}
.sheet-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;}
.sheet-title{font-size:17px;font-weight:800;}
.sheet-close{background:var(--navy2);border:none;color:var(--muted);border-radius:8px;padding:6px 12px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;}
.fl{display:block;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px;margin-top:14px;}
.form-input{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:10px;padding:12px 13px;color:var(--text);font-size:15px;font-family:'Plus Jakarta Sans',sans-serif;outline:none;}
.form-input:focus{border-color:var(--accent);}
select.form-input{cursor:pointer;}
.amount-input{font-family:'JetBrains Mono',monospace;font-size:26px;font-weight:800;text-align:center;border-color:var(--blue);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.btn-primary{width:100%;background:var(--blue);color:#fff;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:800;font-family:inherit;cursor:pointer;margin-top:16px;}
.btn-secondary{width:100%;background:var(--navy2);color:var(--muted);border:1px solid var(--border2);border-radius:12px;padding:12px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;margin-top:8px;}
.btn-danger{width:100%;background:rgba(239,68,68,.1);color:var(--danger);border:1px solid rgba(239,68,68,.2);border-radius:12px;padding:12px;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;margin-top:8px;}
.subtab-row{display:flex;background:var(--bg);border-radius:10px;padding:3px;margin-bottom:14px;}
.subtab{flex:1;padding:8px;border:none;border-radius:8px;background:none;color:var(--muted);font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;}
.subtab.active{background:var(--blue);color:#fff;}
.confirm-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px;}
.confirm-box{background:var(--navy);border:1px solid var(--border2);border-radius:16px;padding:24px;max-width:300px;width:100%;text-align:center;}
.confirm-msg{font-size:15px;font-weight:700;margin-bottom:20px;}
.confirm-btns{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.confirm-no{background:var(--navy2);border:none;color:var(--muted);border-radius:10px;padding:12px;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;}
.confirm-yes{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:var(--danger);border-radius:10px;padding:12px;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;}
.two-col{display:flex;gap:10px;}
.two-col > div{flex:1;min-width:0;}
</style>
</head>
<body>
<div id="lock-screen" style="position:fixed;inset:0;background:#0d1b2a;z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;">
  <div style="background:#122035;border:1px solid #1e3352;border-radius:20px;padding:32px 24px;max-width:320px;width:100%;">
    <div style="text-align:center;margin-bottom:20px;">
      <div style="width:56px;height:56px;background:#1a6fbf;border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
      <div style="font-size:20px;font-weight:800;color:#e2eaf4;">ZZP Manager</div>
    </div>
    <div style="display:flex;background:#0d1b2a;border-radius:10px;padding:4px;margin-bottom:20px;">
      <button id="tab-login" onclick="switchAuthTab('login')" style="flex:1;padding:8px;border:none;border-radius:7px;background:#1a6fbf;color:#fff;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;">Inloggen</button>
      <button id="tab-register" onclick="switchAuthTab('register')" style="flex:1;padding:8px;border:none;border-radius:7px;background:none;color:#4a6a8a;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;">Registreren</button>
    </div>
    <div id="form-login">
      <input type="text" id="login-user" placeholder="Gebruikersnaam" style="width:100%;background:#0d1b2a;border:1px solid #1e3352;border-radius:10px;padding:12px 14px;color:#e2eaf4;font-size:15px;font-family:inherit;outline:none;margin-bottom:8px;" onkeydown="if(event.key==='Enter')doLogin()"/>
      <input type="password" id="login-pwd" placeholder="Wachtwoord" style="width:100%;background:#0d1b2a;border:1px solid #1e3352;border-radius:10px;padding:12px 14px;color:#e2eaf4;font-size:15px;font-family:inherit;outline:none;margin-bottom:12px;" onkeydown="if(event.key==='Enter')doLogin()"/>
      <div id="login-error" style="color:#ef4444;font-size:12px;margin-bottom:10px;min-height:16px;text-align:center;"></div>
      <button onclick="doLogin()" style="width:100%;background:#1a6fbf;color:#fff;border:none;border-radius:12px;padding:13px;font-size:15px;font-weight:800;font-family:inherit;cursor:pointer;">Inloggen</button>
    </div>
    <div id="form-register" style="display:none;">
      <input type="text" id="reg-name" placeholder="Volledige naam" style="width:100%;background:#0d1b2a;border:1px solid #1e3352;border-radius:10px;padding:12px 14px;color:#e2eaf4;font-size:15px;font-family:inherit;outline:none;margin-bottom:8px;"/>
      <input type="text" id="reg-user" placeholder="Gebruikersnaam" style="width:100%;background:#0d1b2a;border:1px solid #1e3352;border-radius:10px;padding:12px 14px;color:#e2eaf4;font-size:15px;font-family:inherit;outline:none;margin-bottom:8px;"/>
      <input type="password" id="reg-pwd" placeholder="Wachtwoord" style="width:100%;background:#0d1b2a;border:1px solid #1e3352;border-radius:10px;padding:12px 14px;color:#e2eaf4;font-size:15px;font-family:inherit;outline:none;margin-bottom:12px;"/>
      <div id="reg-error" style="color:#ef4444;font-size:12px;margin-bottom:10px;min-height:16px;text-align:center;"></div>
      <button onclick="doRegister()" style="width:100%;background:#1a6fbf;color:#fff;border:none;border-radius:12px;padding:13px;font-size:15px;font-weight:800;font-family:inherit;cursor:pointer;">Registreren</button>
    </div>
  </div>
</div>
<div id="app" style="display:none;">
  <div class="top-bar">
    <div style="display:flex;align-items:center;gap:10px;">
      <div class="logo-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
      <div><div class="app-name">ZZP Manager</div><div class="sync-status" id="sync-status">Gereed</div></div>
    </div>
    <button class="fab-top" onclick="openFab()">+ Toevoegen</button>
  </div>
  <div id="content"></div>
  <nav class="bottom-nav">
    <button class="nav-btn active" data-tab="dashboard" onclick="showTab('dashboard')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard
    </button>
    <button class="nav-btn" data-tab="invoices" onclick="showTab('invoices')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Facturen
    </button>
    <button class="nav-btn" data-tab="expenses" onclick="showTab('expenses')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>Uitgaven
    </button>
    <button class="nav-btn" data-tab="calendar" onclick="showTab('calendar')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Kalender
    </button>
    <button class="nav-btn" data-tab="settings" onclick="showTab('settings')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>Instellingen
    </button>
  </nav>
</div>
<script>
var ZZP_AUTH='https://zzp-auth-api.muminmertozturk.workers.dev';
var ZZP_API='https://zzp-api.muminmertozturk.workers.dev';
var CURRENT_USER=null,CURRENT_TOKEN=null,CURRENT_NAME=null;
var _syncTimer=null,currentTab='dashboard',expTab='personal',invSort='date';
var INV_STATUSES=['Openstaand','Betaald','Te laat','Geannuleerd'];
var ZAK_CATS=['Gereedschap / Materiaal','Auto & Reiskosten','Telefoon & Internet','Software & Abonnementen','Verzekeringen','Opleiding & Cursussen','Marketing & Reclame','Kantoorbenodigdheden','Representatie','Administratie & Boekhouding','Overig zakelijk'];
var PRIV_CATS=['Boodschappen','Huur & Energie','Zorgkosten','Transport','Kleding','Horeca','Overig privé'];

var DB={
  get:function(k){try{return JSON.parse(localStorage.getItem('zzpm_'+k)||'[]');}catch(e){return[];}},
  set:function(k,v){localStorage.setItem('zzpm_'+k,JSON.stringify(v));autoSync();}
};
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,5);}
function pa(s){return parseFloat(String(s).replace(',','.'))||0;}
function fmtEUR(n){return'€ '+pa(n).toFixed(2).replace('.',',');}
function today(){var d=new Date();return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function addDays(ds,n){var d=new Date(ds+'T00:00:00');d.setDate(d.getDate()+n);return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function fmtDate(ds){if(!ds)return'';var p=ds.split('-');return p[2]+'-'+p[1]+'-'+p[0];}
function updateSyncStatus(msg){var el=document.getElementById('sync-status');if(el)el.textContent=msg;}
function statusClass(s){return'status-'+s.toLowerCase().replace(/\s+/g,'').replace('telaat','telaat');}

function switchAuthTab(tab){
  var lf=document.getElementById('form-login'),rf=document.getElementById('form-register');
  var tl=document.getElementById('tab-login'),tr=document.getElementById('tab-register');
  if(tab==='login'){lf.style.display='';rf.style.display='none';tl.style.background='#1a6fbf';tl.style.color='#fff';tr.style.background='none';tr.style.color='#4a6a8a';}
  else{rf.style.display='';lf.style.display='none';tr.style.background='#1a6fbf';tr.style.color='#fff';tl.style.background='none';tl.style.color='#4a6a8a';}
}
function doLogin(){
  var usr=(document.getElementById('login-user')||{}).value.trim().toLowerCase();
  var pwd=(document.getElementById('login-pwd')||{}).value;
  var err=document.getElementById('login-error');
  if(!usr||!pwd){err.textContent='Vul alle velden in';return;}
  err.textContent='Bezig...';
  fetch(ZZP_AUTH+'/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:usr,password:pwd})})
    .then(function(r){return r.json();})
    .then(function(data){
      if(data.error){if(data.error==='pending'){err.textContent='Wacht op goedkeuring.';return;}if(data.error==='rejected'){err.textContent='Account afgewezen.';return;}err.textContent=data.error;return;}
      CURRENT_USER=data.username;CURRENT_TOKEN=data.token;CURRENT_NAME=data.name;
      document.getElementById('lock-screen').remove();document.getElementById('app').style.display='flex';
      loadFromCloud();
    }).catch(function(){err.textContent='Verbindingsfout';});
}
function doRegister(){
  var name=(document.getElementById('reg-name')||{}).value.trim();
  var usr=(document.getElementById('reg-user')||{}).value.trim().toLowerCase().replace(/\s+/g,'-');
  var pwd=(document.getElementById('reg-pwd')||{}).value;
  var err=document.getElementById('reg-error');
  if(!name||!usr||!pwd){err.textContent='Vul alle velden in';return;}
  err.textContent='Bezig...';
  fetch(ZZP_AUTH+'/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:usr,name:name,password:pwd})})
    .then(function(r){return r.json();})
    .then(function(data){
      if(data.error){err.textContent=data.error;return;}
      err.style.color='#34d399';err.textContent='Geregistreerd! Wacht op goedkeuring.';
    }).catch(function(){err.textContent='Verbindingsfout';});
}

function autoSync(){if(_syncTimer)clearTimeout(_syncTimer);_syncTimer=setTimeout(syncToCloud,1500);}
function syncToCloud(){
  if(!CURRENT_USER||!CURRENT_TOKEN)return;
  var data={invoices:DB.get('invoices'),exp_personal:DB.get('exp_personal'),exp_business:DB.get('exp_business'),customers:DB.get('customers')};
  fetch(ZZP_API,{method:'POST',headers:{'Content-Type':'application/json','X-Username':CURRENT_USER,'X-Token':CURRENT_TOKEN},body:JSON.stringify(data)})
    .then(function(){updateSyncStatus('Opgeslagen ✓');}).catch(function(){updateSyncStatus('Sync mislukt');});
}
function loadFromCloud(){
  if(!CURRENT_USER||!CURRENT_TOKEN){checkOverduePrompt();showTab('dashboard');return;}
  updateSyncStatus('Laden...');
  fetch(ZZP_API,{headers:{'X-Username':CURRENT_USER,'X-Token':CURRENT_TOKEN}})
    .then(function(r){return r.json();})
    .then(function(data){
      if(data&&typeof data==='object'){
        if(data.invoices)localStorage.setItem('zzpm_invoices',JSON.stringify(data.invoices));
        if(data.exp_personal)localStorage.setItem('zzpm_exp_personal',JSON.stringify(data.exp_personal));
        if(data.exp_business)localStorage.setItem('zzpm_exp_business',JSON.stringify(data.exp_business));
        if(data.customers)localStorage.setItem('zzpm_customers',JSON.stringify(data.customers));
      }
      updateSyncStatus('Geladen ✓');checkOverduePrompt();showTab('dashboard');
    }).catch(function(){updateSyncStatus('Offline');checkOverduePrompt();showTab('dashboard');});
}

function checkOverduePrompt(){
  var inv=DB.get('invoices'),td=today();
  var overdue=inv.filter(function(i){return i.status==='Openstaand'&&i.dueDate&&i.dueDate<td;});
  if(overdue.length)showOverduePrompt(overdue,0);
}
function showOverduePrompt(overdue,idx){
  if(idx>=overdue.length)return;
  var i=overdue[idx];
  var ov=document.createElement('div');
  ov.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:9000;display:flex;align-items:center;justify-content:center;padding:20px;';
  var box=document.createElement('div');
  box.style.cssText='background:var(--navy);border:1px solid var(--border2);border-radius:18px;padding:24px;max-width:320px;width:100%;text-align:center;';
  box.innerHTML='<div style="font-size:28px;margin-bottom:8px">💰</div><div style="font-size:15px;font-weight:800;margin-bottom:6px">Betaald?</div>'
    +'<div style="font-size:13px;color:var(--muted2);margin-bottom:4px">'+i.client+'</div>'
    +'<div style="font-size:22px;font-weight:800;color:var(--warn);margin-bottom:4px">'+fmtEUR(i.amount)+'</div>'
    +'<div style="font-size:11px;color:var(--muted2);margin-bottom:20px">Vervaldatum: '+fmtDate(i.dueDate)+'</div>'
    +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">'
      +'<button id="op-no" style="background:var(--navy2);border:1px solid var(--border2);color:var(--muted);border-radius:10px;padding:13px;font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;">Nog niet</button>'
      +'<button id="op-yes" style="background:rgba(16,185,129,.15);border:1px solid rgba(16,185,129,.3);color:var(--success);border-radius:10px;padding:13px;font-size:14px;font-weight:800;font-family:inherit;cursor:pointer;">Betaald ✓</button>'
    +'</div>'+(overdue.length>1?'<div style="font-size:10px;color:var(--muted2);margin-top:12px">'+(idx+1)+' / '+overdue.length+'</div>':'');
  ov.appendChild(box);document.body.appendChild(ov);
  document.getElementById('op-yes').addEventListener('click',function(){
    var inv=DB.get('invoices');inv=inv.map(function(x){return x.id===i.id?Object.assign({},x,{status:'Betaald'}):x;});
    DB.set('invoices',inv);ov.remove();if(currentTab==='dashboard')renderDashboard();showOverduePrompt(overdue,idx+1);
  });
