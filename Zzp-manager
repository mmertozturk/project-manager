// ==================== CALENDAR ====================
function renderCalendar(){
  var now=new Date();
  window._cy=window._cy||now.getFullYear();
  window._cm=window._cm!==undefined?window._cm:now.getMonth();
  drawCal(window._cy,window._cm);
}

function drawCal(y,m){
  var inv=DB.get('invoices');
  var expP=DB.get('exp_personal');
  var expB=DB.get('exp_business');
  var evts={};
  inv.forEach(function(i){if(i.dueDate){var k=i.dueDate;if(!evts[k])evts[k]=[];evts[k].push({type:'inv',label:i.client,amt:i.amount,status:i.status});}});
  [].concat(expP,expB).forEach(function(e){if(e.date){var k=e.date;if(!evts[k])evts[k]=[];evts[k].push({type:'exp',label:e.desc,amt:e.amount});}});
  window._evts=evts;

  var MONTHS=['Januari','Februari','Maart','April','Mei','Juni','Juli','Augustus','September','Oktober','November','December'];
  var DAYS=['Ma','Di','Wo','Do','Vr','Za','Zo'];
  var td=today();
  var first=new Date(y,m,1);
  var dow=(first.getDay()+6)%7;
  var dim=new Date(y,m+1,0).getDate();
  var off=dow;

  var h='<div class="page">'
    +'<div class="page-title">Kalender</div>'
    +'<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">'
      +'<button onclick="moveCal(-1)" style="background:var(--navy2);border:none;color:var(--text);border-radius:8px;width:36px;height:36px;font-size:18px;cursor:pointer">‹</button>'
      +'<div style="font-size:16px;font-weight:800">'+MONTHS[m]+' '+y+'</div>'
      +'<button onclick="moveCal(1)" style="background:var(--navy2);border:none;color:var(--text);border-radius:8px;width:36px;height:36px;font-size:18px;cursor:pointer">›</button>'
    +'</div>'
    +'<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:8px">';
  DAYS.forEach(function(d){h+='<div style="text-align:center;font-size:10px;font-weight:700;color:var(--muted2);padding:4px 0">'+d+'</div>';});
  h+='</div><div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px">';
  for(var i=0;i<off;i++)h+='<div></div>';
  for(var d2=1;d2<=dim;d2++){
    var mo=String(m+1).padStart(2,'0');
    var d2s=String(d2).padStart(2,'0');
    var ds=y+'-'+mo+'-'+d2s;
    var ev=evts[ds]||[];
    var isT=(ds===td);
    var hasI=ev.some(function(e){return e.type==='inv';});
    var hasE=ev.some(function(e){return e.type==='exp';});
    var dots='';
    if(hasI)dots+='<div style="width:5px;height:5px;border-radius:50%;background:var(--success);margin:0 1px"></div>';
    if(hasE)dots+='<div style="width:5px;height:5px;border-radius:50%;background:var(--danger);margin:0 1px"></div>';
    var dsj=JSON.stringify(ds);
    h+='<div onclick="calDay('+dsj+')" style="background:'+(isT?'var(--blue)':'var(--navy2)')+';border-radius:8px;padding:6px 2px;text-align:center;cursor:'+(ev.length?'pointer':'default')+';">'
      +'<div style="font-size:13px;font-weight:'+(isT?'800':'600')+';color:'+(isT?'#fff':'var(--text)')+'">'+d2+'</div>'
      +'<div style="display:flex;justify-content:center;margin-top:2px;min-height:7px">'+dots+'</div>'
      +'</div>';
  }
  h+='</div>'
    +'<div style="display:flex;gap:12px;margin-top:12px;font-size:11px">'
      +'<div style="display:flex;align-items:center;gap:4px"><div style="width:8px;height:8px;border-radius:50%;background:var(--success)"></div>Vervaldatum</div>'
      +'<div style="display:flex;align-items:center;gap:4px"><div style="width:8px;height:8px;border-radius:50%;background:var(--danger)"></div>Uitgave</div>'
    +'</div>'
    +'</div>';
  document.getElementById('content').innerHTML=h;
}

function moveCal(dir){window._cm+=dir;if(window._cm>11){window._cm=0;window._cy++;}if(window._cm<0){window._cm=11;window._cy--;}drawCal(window._cy,window._cm);}

function calDay(ds){
  var evts=window._evts||{};var ev=evts[ds]||[];if(!ev.length)return;
  var p=ds.split('-');
  var rows=ev.map(function(e){
    var c=e.type==='inv'?'var(--success)':'var(--danger)';
    var lbl=e.type==='inv'?'Factuur':'Uitgave';
    return'<div class="row"><div class="row-main"><div class="row-name">'+e.label+'</div><div class="row-sub">'+lbl+(e.status?' · '+e.status:'')+'</div></div><div class="row-amount" style="color:'+c+'">'+fmtEUR(e.amt)+'</div></div>';
  }).join('');
  openSheet('<div class="sheet-header"><div class="sheet-title">'+p[2]+' / '+p[1]+' / '+p[0]+'</div><button class="sheet-close" onclick="closeSheet()">Sluiten</button></div><div class="card">'+rows+'</div>');
}

