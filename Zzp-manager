<script>
var ZZP_AUTH = 'https://zzp-auth-api.muminmertozturk.workers.dev';
var ZZP_API = 'https://zzp-api.muminmertozturk.workers.dev';
var CURRENT_USER = null;
var CURRENT_TOKEN = null;
var CURRENT_NAME = null;

function switchAuthTab(tab){
  var lf=document.getElementById('form-login');
  var rf=document.getElementById('form-register');
  var tl=document.getElementById('tab-login');
  var tr=document.getElementById('tab-register');
  if(tab==='login'){
    lf.style.display='';rf.style.display='none';
    tl.style.background='#1a6fbf';tl.style.color='#fff';
    tr.style.background='none';tr.style.color='#4a6a8a';
  } else {
    rf.style.display='';lf.style.display='none';
    tr.style.background='#1a6fbf';tr.style.color='#fff';
    tl.style.background='none';tl.style.color='#4a6a8a';
  }
}

function doLogin(){
  var usr=(document.getElementById('login-user')||{}).value.trim().toLowerCase();
  var pwd=(document.getElementById('login-pwd')||{}).value;
  var err=document.getElementById('login-error');
  if(!usr||!pwd){err.textContent='Vul alle velden in';return;}
  err.textContent='Bezig...';
  fetch(ZZP_AUTH+'/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:usr,password:pwd})})
    .then(function(r){return r.json();})
    .then(function(data){
      if(data.error){
        if(data.error==='pending'){err.textContent='Account wacht op goedkeuring van admin.';return;}
        if(data.error==='rejected'){err.textContent='Account is afgewezen.';return;}
        err.textContent=data.error;return;
      }
      CURRENT_USER=data.username;CURRENT_TOKEN=data.token;CURRENT_NAME=data.name;
      document.getElementById('lock-screen').remove();
      document.getElementById('app').style.display='flex';
      loadFromCloud();
    }).catch(function(){err.textContent='Verbindingsfout';});
}

function doRegister(){
  var name=(document.getElementById('reg-name')||{}).value.trim();
  var usr=(document.getElementById('reg-user')||{}).value.trim().toLowerCase().replace(/\s+/g,'-');
  var pwd=(document.getElementById('reg-pwd')||{}).value;
  var err=document.getElementById('reg-error');
  if(!name||!usr||!pwd){err.textContent='Vul alle velden in';return;}
  if(usr.length<3){err.textContent='Gebruikersnaam min 3 tekens';return;}
  err.textContent='Bezig...';
  fetch(ZZP_AUTH+'/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:usr,name:name,password:pwd})})
    .then(function(r){return r.json();})
    .then(function(data){
      if(data.error){err.textContent=data.error;return;}
      err.style.color='#34d399';
      err.textContent='Geregistreerd! Wacht op goedkeuring van admin.';
      document.getElementById('reg-name').value='';
      document.getElementById('reg-user').value='';
      document.getElementById('reg-pwd').value='';
    }).catch(function(){err.textContent='Verbindingsfout';});
}

function loadFromCloud(){
  if(!CURRENT_USER||!CURRENT_TOKEN){checkAutoStatus();showTab('dashboard');return;}
  updateSyncStatus('Laden...');
  fetch(ZZP_API,{headers:{'X-Username':CURRENT_USER,'X-Token':CURRENT_TOKEN}})
    .then(function(r){return r.json();})
    .then(function(data){
      if(data&&typeof data==='object'){
        if(data.invoices)localStorage.setItem('zzpm_invoices',JSON.stringify(data.invoices));
        if(data.exp_personal)localStorage.setItem('zzpm_exp_personal',JSON.stringify(data.exp_personal));
        if(data.exp_business)localStorage.setItem('zzpm_exp_business',JSON.stringify(data.exp_business));
        if(data.customers)localStorage.setItem('zzpm_customers',JSON.stringify(data.customers));
      }
      checkAutoStatus();showTab('dashboard');
      updateSyncStatus('Geladen ✓');
    }).catch(function(){checkAutoStatus();showTab('dashboard');updateSyncStatus('Offline');});
}

function syncToCloud(){
  if(!CURRENT_USER||!CURRENT_TOKEN)return;
  var data={
    invoices:DB.get('invoices'),
    exp_personal:DB.get('exp_personal'),
    exp_business:DB.get('exp_business'),
    customers:DB.get('customers')
  };
  fetch(ZZP_API,{method:'POST',headers:{'Content-Type':'application/json','X-Username':CURRENT_USER,'X-Token':CURRENT_TOKEN},body:JSON.stringify(data)})
    .then(function(){updateSyncStatus('Opgeslagen ✓');})
    .catch(function(){updateSyncStatus('Sync mislukt');});
}

// --- DB ---
var DB={
  get:function(k){try{return JSON.parse(localStorage.getItem('zzpm_'+k)||'[]');}catch(e){return[];}},
  set:function(k,v){localStorage.setItem('zzpm_'+k,JSON.stringify(v));autoSync();},
  getObj:function(k,def){try{return JSON.parse(localStorage.getItem('zzpm_'+k)||JSON.stringify(def));}catch(e){return def;}},
  setObj:function(k,v){localStorage.setItem('zzpm_'+k,JSON.stringify(v));autoSync();}
};

function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,5);}
function pa(s){return parseFloat(String(s).replace(',','.'))||0;}
function fmtEUR(n){return'€ '+pa(n).toFixed(2).replace('.',',');}
function today(){var d=new Date();return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function addDays(ds,n){var d=new Date(ds);d.setDate(d.getDate()+n);return d.toFullYear?d.toFullYear():d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function fmtDate(ds){if(!ds)return'';var p=ds.split('-');return p[2]+'-'+p[1]+'-'+p[0];}

// Fix addDays
function addDays(ds,n){var d=new Date(ds+'T00:00:00');d.setDate(d.getDate()+n);return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}

var INV_STATUSES=['Beklemende','Betaald','Gecikmis','İptal'];

// --- SYNC ---
var _syncTimer=null;
function autoSync(){
  if(_syncTimer)clearTimeout(_syncTimer);
  _syncTimer=setTimeout(syncToCloud,1500);
}
function updateSyncStatus(msg){var el=document.getElementById('sync-status');if(el)el.textContent=msg;}

// --- AUTO STATUS ---
function checkAutoStatus(){
  var inv=DB.get('invoices');
  var td=today();
  var changed=false;
  inv=inv.map(function(i){
    if(i.status==='Beklemende'&&i.dueDate&&i.dueDate<td){
      i.status='Gecikmis';changed=true;
    }
    return i;
  });
  if(changed)localStorage.setItem('zzpm_invoices',JSON.stringify(inv));
}

// --- NAVIGATION ---
var currentTab='dashboard';
function showTab(tab){
  currentTab=tab;
  document.querySelectorAll('.nav-btn').forEach(function(b){b.classList.toggle('active',b.dataset.tab===tab);});
  document.getElementById('content').scrollTop=0;
  if(tab==='dashboard')renderDashboard();
  else if(tab==='invoices')renderInvoices();
  else if(tab==='expenses')renderExpenses();
  else if(tab==='calendar')renderCalendar();
  else if(tab==='settings')renderSettings();
}

function openFab(){
  if(currentTab==='invoices')openInvoiceForm(null);
  else if(currentTab==='expenses')openExpenseForm(null);
  else if(currentTab==='settings')openKlantForm();
  else openInvoiceForm(null);
}

// --- CUSTOM CONFIRM ---
function customConfirm(msg,onYes){
  var ov=document.createElement('div');ov.className='confirm-overlay';
  var box=document.createElement('div');box.className='confirm-box';
  var m=document.createElement('div');m.className='confirm-msg';m.textContent=msg;
  var btns=document.createElement('div');btns.className='confirm-btns';
  var no=document.createElement('button');no.className='confirm-no';no.textContent='Annuleren';
  no.addEventListener('click',function(){ov.remove();});
  var yes=document.createElement('button');yes.className='confirm-yes';yes.textContent='Verwijderen';
  yes.addEventListener('click',function(){ov.remove();onYes();});
  btns.appendChild(no);btns.appendChild(yes);
  box.appendChild(m);box.appendChild(btns);ov.appendChild(box);document.body.appendChild(ov);
}

