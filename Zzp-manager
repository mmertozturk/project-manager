      +'<div class="row-main"><div class="row-name">'+i.client+'</div><div class="row-sub">'+fmtDate(i.date)+'</div></div>'
      +'<span class="row-status '+sc+'">'+i.status+'</span>'
      +'<div class="row-amount" style="color:'+(i.status==='Betaald'?'var(--success)':i.status==='Gecikmis'?'var(--danger)':'var(--warn)')+'">'+fmtEUR(i.amount)+'</div>'
      +'</div>';
  }).join(''):'<div style="text-align:center;padding:16px;color:var(--muted2);font-size:13px;">Geen facturen</div>';

  document.getElementById('content').innerHTML=
    '<div class="page">'
    +'<div class="page-title">Dashboard</div>'
    +'<div class="stat-grid">'
      +'<div class="stat"><div class="stat-label">Ontvangen</div><div class="stat-val" style="color:var(--success)">'+fmtEUR(paid)+'</div></div>'
      +'<div class="stat"><div class="stat-label">Openstaand</div><div class="stat-val" style="color:var(--warn)">'+fmtEUR(pend)+'</div></div>'
      +'<div class="stat"><div class="stat-label">Te laat</div><div class="stat-val" style="color:var(--danger)">'+fmtEUR(late)+'</div></div>'
      +'<div class="stat"><div class="stat-label">Uitgaven</div><div class="stat-val" style="color:var(--muted)">'+fmtEUR(totalExp)+'</div></div>'
    +'</div>'
    +'<div class="stat-grid">'
      +'<div class="stat" style="border-color:#4fc3f744"><div class="stat-label">30% Reservering</div><div class="stat-val" style="color:var(--accent);font-size:18px">'+fmtEUR(res)+'</div></div>'
      +'<div class="stat"><div class="stat-label">Netto winst</div><div class="stat-val" style="color:'+nc+';font-size:18px">'+fmtEUR(net)+'</div></div>'
    +'</div>'
